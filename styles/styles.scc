html, 
body{
    width: 100px;
    margin: 0;
    padding: 0;  
}

body{
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    padding-top: 147px;
}

.page-header {
position: fixed;
top: 0;
left: 0;
width: 100%;
height: 147px;
background-color: red;
}

.main {
flex: 1 0 auto;
background-color: grey;
}

.page-footer {
flex: 0 0 auto;
background-color: blue;
}
